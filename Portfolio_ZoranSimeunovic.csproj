<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="SyncWorkerService/**" />
    <Content Remove="SyncWorkerService/**" />
    <EmbeddedResource Remove="SyncWorkerService/**" />
    <None Remove="SyncWorkerService/**" />
    <Compile Remove="MsGraphClient/**" />
    <Content Remove="MsGraphClient/**" />
    <EmbeddedResource Remove="MsGraphClient/**" />
    <None Remove="MsGraphClient/**" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="MsGraphClient\MsGraphClient.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.10" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.10">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Pomelo.EntityFrameworkCore.MySql" Version="8.0.2" />
  </ItemGroup>

</Project>
