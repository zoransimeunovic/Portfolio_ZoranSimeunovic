<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — @ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav class="admin-nav">
            <span class="admin-nav-brand">Portfolio Admin</span>
            <div class="admin-nav-links">
                <a href="/admin" class="admin-nav-link">Upitnici</a>
                <a href="/admin/documents" class="admin-nav-link">Dokumenti</a>
                <a href="/admin/logout" class="admin-nav-link admin-nav-link--logout">Odjava</a>
            </div>
        </nav>
    }
    <main class="admin-main">
        @RenderBody()
    </main>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
