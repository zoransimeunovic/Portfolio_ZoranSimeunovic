@model SiteText
@{
    ViewData["Title"] = null;
}

<!-- ============================ HERO (Figma 1440 stage) ============================ -->
<section class="hero" id="home">
    <div class="hero-stage">
        <!-- Vizual / art -->
        <div class="hero-visual" aria-hidden="true">
            <div class="hero-glow"></div>
            <span class="hero-ring hero-ring-3"></span>
            <span class="hero-ring hero-ring-2"></span>
            <span class="hero-ring hero-ring-1"></span>
            <img class="hero-photo" src="~/images/profile.webp" alt="" />
            <div class="hero-photo-fade"></div>

            <span class="float-tag tag-webflow">Webflow</span>
            <span class="float-tag tag-api">API</span>
            <span class="float-tag tag-figma">Figma</span>
            <span class="float-tag tag-mysql">MySQL</span>
            <span class="float-tag tag-aspnet">ASP.NET</span>

            <span class="hero-name-tag">@Model.Hero.Name</span>
        </div>

        <!-- Tekst / copy -->
        <div class="hero-copy">
            <span class="badge-pill">@Model.Hero.Badge</span>
            <h1 class="hero-heading">@Html.Raw(Model.Hero.HeadingHtml)</h1>
            <p class="hero-sub">@Model.Hero.Subtitle1 @Model.Hero.Subtitle2</p>

            <div class="hero-actions">
                <a href="#contact" class="btn-hero-primary">@Model.Hero.ContactMe</a>
                <a href="#work" class="btn-hero-secondary">
                    <img src="~/images/icons/my-work.png" alt="" /> @Model.Hero.MyWork
                </a>
            </div>

            <div class="hero-proof">
                <div class="avatars">
                    <img src="~/images/avatars/Pfoto1.webp" alt="" />
                    <img src="~/images/avatars/Pfoto2.webp" alt="" />
                    <img src="~/images/avatars/Pfoto3.webp" alt="" />
                    <img src="~/images/avatars/Pfoto4.webp" alt="" />
                    <img src="~/images/avatars/Pfoto5.webp" alt="" />
                    <span class="avatar-more">+5</span>
                </div>
                <span class="proof-text">@Model.Hero.ProjectsCount</span>
            </div>
        </div>
    </div>
</section>

<!-- ============================ WORK ============================ -->
<section class="work" id="work">
<div class="container">
        <div class="section-head text-center">
            <span class="section-label">@Model.Work.Label</span>
            <h2 class="section-title">@Html.Raw(Model.Work.TitleHtml)</h2>
            <p class="section-sub">@Model.Work.Subtitle</p>
        </div>

        <div class="work-carousel" data-carousel>
            <button class="carousel-btn prev" data-prev aria-label="@Model.Work.PrevLabel">&#8249;</button>
            <div class="carousel-viewport">
                <div class="carousel-track" data-track>
                    @foreach (var card in Model.Work.Cards)
                    {
                        <article class="work-card">
                            <div class="work-card-img">
                                <img class="work-card-photo@(card.Image == "hris.webp" ? "" : " work-card-photo--sm")" src="~/images/work/@card.Image" alt="@card.Title" />
                                @if (card.Duration != null)
                                {
                                    if (card.DurationUrl != null)
                                    {
                                        <a class="work-badge" href="@card.DurationUrl" target="_blank" rel="noopener noreferrer">
                                            <strong>@card.Duration</strong>
                                            <span>@card.DurationSub</span>
                                        </a>
                                    }
                                    else
                                    {
                                        <div class="work-badge">
                                            <strong>@card.Duration</strong>
                                            <span>@card.DurationSub</span>
                                        </div>
                                    }
                                }
                            </div>
                            <div class="work-card-body">
                                <h3 class="work-card-title">@card.Title</h3>
                                <p class="work-card-desc">@card.Description</p>
                                <div class="work-techs">
                                    @foreach (var tech in card.Techs)
                                    {
                                        <span class="tech-tag">@tech</span>
                                    }
                                </div>
                            </div>
                        </article>
                    }
                </div>
            </div>
            <button class="carousel-btn next" data-next aria-label="@Model.Work.NextLabel">&#8250;</button>
        </div>
    </div>
</section>

<!-- ============================ ABOUT (Figma 1440×748 stage) ============================ -->
<section class="about" id="about">
    <div class="about-stage fig-stage">
        <!-- Slika (lijevo) -->
        <div class="ab-visual" aria-hidden="true">
            <div class="ab-glow"></div>
            <span class="ab-ring ab-ring-2"></span>
            <span class="ab-ring ab-ring-1"></span>
            <div class="ab-photo"><img src="~/images/profile.webp" alt="" /></div>
            <a class="ab-go" href="https://europeangodatabase.eu/EGD/Player_Card.php?&key=10350087" target="_blank" rel="noopener" aria-label="@Model.About.GoPlayer">
                <span>Go Player</span>
            </a>
            <a class="ab-linkedin" href="https://www.linkedin.com/in/zoran-simeunovic-3749b991" target="_blank" rel="noopener" aria-label="LinkedIn">
                <img class="ab-li-rect" src="~/images/icons/Vector_LinekdIn.png" alt="" aria-hidden="true" />
                <img class="ab-li-sign" src="~/images/icons/linkedin_in_about.png" alt="" aria-hidden="true" />
            </a>
        </div>

        <!-- Intro tekst: label, naslov, opis (iznad slike na tabletu/mobilnom) -->
        <div class="ab-intro">
            <span class="ab-label">@Model.About.Label</span>
            <div class="ab-msg" aria-hidden="true"><span>@Model.About.Name</span></div>
            <h2 class="ab-title">@Html.Raw(Model.About.HeadingHtml)</h2>
            <p class="ab-desc">@Model.About.Description</p>
        </div>

        <!-- Highlights i akcije (ispod slike na tabletu/mobilnom) -->
        <div class="ab-copy">
            <div class="ab-highlights">
                <div class="ab-hl">@Html.Raw(Model.About.Highlight1Html)</div>
                <div class="ab-hl">@Html.Raw(Model.About.Highlight2Html)</div>
                <div class="ab-hl">@Html.Raw(Model.About.Highlight3Html)</div>
            </div>

            <div class="ab-actions">
                <a href="#contact" class="ab-btn-primary">@Model.About.ContactMe</a>
                @{
                    var cvFile = Model.Culture.StartsWith("de") ? "Lebenslauf_Zoran Simeunovic.pdf" : "CV_Zoran Simeunovic.pdf";
                    var cvHref = Url.Content("~/files/" + cvFile).Replace(" ", "%20");
                }
                <a href="@cvHref" download class="ab-btn-secondary">
                    <img src="~/images/icons/download-cv.png" alt="" /> @Model.About.DownloadCv
                </a>
            </div>
        </div>
    </div>
</section>

<!-- ============================ PROCESS ============================ -->
<section class="process" id="process">
    <div class="container">
        <div class="section-head">
            <span class="section-label">@Model.Process.Label</span>
            <h2 class="section-title">@Html.Raw(Model.Process.TitleHtml)</h2>
        </div>

        <div class="process-wrap">
            <div class="process-grid">
                @for (var i = 0; i < Model.Process.Steps.Count; i++)
                {
                    var step = Model.Process.Steps[i];
                    var cardClass = "process-card";
                    if (i == 4) cardClass += " process-card--featured";
                    if (i == 7 || i == 8 || i == 10) cardClass += " process-card--optional";
                    if (i >= 3) cardClass += " process-card--collapsed";
                    <div class="@cardClass">
                        <span class="step-num">@(i + 1)</span>
                        <span class="step-tag">@step.Tag</span>
                        @if (i == 0)
                        {
                            <a href="#contact" class="btn btn-accent step-cta">@Model.Process.ContactMe</a>
                            <p class="step-desc">@Model.Process.FindMe</p>
                        }
                        else
                        {
                            <h3 class="step-title">@step.Title</h3>
                            <p class="step-desc">@step.Description</p>
                        }
                    </div>
                }
                <button type="button" class="process-toggle" data-process-toggle
                        data-show="@Model.Process.ShowAll" data-hide="@Model.Process.HideAll">
                    <span>@Model.Process.ShowAll</span>
                    <span class="toggle-icon" aria-hidden="true"></span>
                </button>
            </div>
        </div>
    </div>
</section>

<!-- ============================ PRICING ============================ -->
<section class="pricing" id="pricing">
    <div class="container">
        <div class="section-head">
            <span class="section-label">@Model.Pricing.Label</span>
            <h2 class="section-title">@Model.Pricing.Title</h2>
            <p class="section-sub">@Model.Pricing.Subtitle</p>
            <div class="pricing-tags">
                @foreach (var badge in Model.Pricing.Badges)
                {
                    <span class="pricing-tag">@badge</span>
                }
            </div>
        </div>

        <div class="pricing-carousel" data-pricing-carousel>
            <button class="carousel-btn prev" data-pricing-prev aria-label="@Model.Pricing.PrevLabel">&#8249;</button>
            <div class="carousel-viewport">
                <div class="carousel-track" data-pricing-track>
                    @for (var i = 0; i < Model.Pricing.Cards.Count; i++)
                    {
                        var card = Model.Pricing.Cards[i];
                        <article class="pricing-card@(card.IsRecommended ? " pricing-card--featured" : "")">
                            @if (card.IsRecommended)
                            {
                                <span class="pricing-badge">@Model.Pricing.BadgeRecommended</span>
                            }
                            <div class="pricing-head">
                                <h3 class="pricing-name">@card.Name</h3>
                                <p class="pricing-price">@card.Price</p>
                            </div>
                            <ul class="pricing-features">
                                @foreach (var feature in card.Features)
                                {
                                    <li>@feature</li>
                                }
                            </ul>
                            <div class="pricing-footer">
                                <span class="pricing-warranty">@card.WarrantyDays @Model.Pricing.WarrantyUnit</span>
                                <a href="#contact" class="btn btn-accent pricing-cta">@Model.Pricing.GetStarted</a>
                            </div>
                        </article>
                    }
                </div>
            </div>
            <button class="carousel-btn next" data-pricing-next aria-label="@Model.Pricing.NextLabel">&#8250;</button>
        </div>

        <div class="pricing-cta-block">
            <h3 class="pricing-cta-heading">@Model.Pricing.CtaHeading</h3>
            <p class="pricing-cta-text">@Model.Pricing.CtaText</p>
            <a href="#contact" class="btn btn-accent pricing-cta-btn">@Model.Pricing.CtaButton</a>
        </div>

    </div>
</section>

<!-- ============================ IMPROVE ============================ -->
<section class="improve" id="improve">
    <div class="container">
        <div class="improve-rings" aria-hidden="true"></div>
        <div class="improve-glow" aria-hidden="true"></div>
        <div class="section-head">
            <h2 class="section-title">@Html.Raw(Model.Improve.TitleHtml)</h2>
            <p class="section-sub">@Model.Improve.Subtitle1<br />@Model.Improve.Subtitle2</p>
        </div>

        <div class="improve-grid">
            @foreach (var list in Model.Improve.Lists)
            {
                <div class="improve-col" data-checklist data-key="@list.Key">
                    <div class="improve-bar">
                        <h3 class="improve-heading">@Html.Raw(list.HeadingHtml)</h3>
                        <button type="button" class="improve-toggle" data-toggle-list
                                data-open="@Model.Improve.StartAnalysis" data-close="@Model.Improve.CloseChecklist">
                            <span>@Model.Improve.StartAnalysis</span>
                            <span class="toggle-icon" aria-hidden="true"></span>
                        </button>
                    </div>

                    <div class="improve-body" data-body hidden>
                        @foreach (var group in list.Groups)
                        {
                            <div class="check-group">
                                <h4 class="check-group-title">@group.Title</h4>
                                @foreach (var item in group.Items)
                                {
                                    <label class="check-item">
                                        <input type="checkbox" data-check />
                                        <span>@item</span>
                                    </label>
                                }
                            </div>
                        }

                        <div class="analyze-row">
                            <button type="button" class="analyze-btn" data-analyze>@Model.Improve.Analyze</button>
                        </div>
                        <div class="score-box" data-score hidden>
                            @foreach (var band in list.Scores)
                            {
                                <span class="score-band" data-min="@band.Min" data-max="@band.Max" hidden>@band.Text</span>
                            }
                            <span class="score-text" data-score-text></span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ============================ LAST CTA (Take the first step) ============================ -->
<section class="contact" id="contact">
    <div class="container">
        <div class="cta-card">
            <div class="cta-circles" aria-hidden="true">
                <span class="cta-circle c1"></span>
                <span class="cta-circle c2"></span>
                <span class="cta-circle c3"></span>
            </div>
            <div class="cta-content">
                <h2 class="cta-title">@Html.Raw(Model.Contact.TitleHtml)</h2>
                <p class="cta-sub">@Model.Contact.Subtitle1 @Model.Contact.Subtitle2</p>

                <div id="selectedPackageTag" class="selected-package-tag" hidden>
                    <span id="selectedPackageName"></span>
                    <button type="button" id="clearPackageBtn" aria-label="Clear">&#215;</button>
                </div>
                <form id="contactForm" class="cta-form"
                      asp-controller="Home" asp-action="Contact" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="package" id="selectedPackage" />
                    <input type="text" name="name" required placeholder="@Model.Contact.NamePlaceholder" />
                    <input type="email" name="email" required placeholder="@Model.Contact.EmailPlaceholder" />
                    <button type="submit" class="cta-submit">@Model.Contact.GetStarted</button>
                </form>

                <p class="cta-note">@Html.Raw(Model.Contact.PrivacyNoteHtml)</p>
                <p class="contact-result" data-result hidden></p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
(function () {
    var root = document.querySelector("[data-pricing-carousel]");
    if (!root) return;
    var track = root.querySelector("[data-pricing-track]");
    var prevBtn = root.querySelector("[data-pricing-prev]");
    var nextBtn = root.querySelector("[data-pricing-next]");
    if (!track) return;

    var realCards = Array.prototype.slice.call(track.children);
    var n = realCards.length;
    if (n === 0) return;

    for (var i = n - 1; i >= 0; i--) {
        var pre = realCards[i].cloneNode(true);
        pre.setAttribute("aria-hidden", "true");
        track.insertBefore(pre, track.firstChild);
    }
    realCards.forEach(function (c) {
        var post = c.cloneNode(true);
        post.setAttribute("aria-hidden", "true");
        track.appendChild(post);
    });

    var index = n;
    var busy = false;

    function step() {
        var style = window.getComputedStyle(track);
        var gap = parseFloat(style.columnGap || style.gap || "0") || 0;
        return realCards[0].getBoundingClientRect().width + gap;
    }

    function setPos(i, animate) {
        if (!animate) {
            track.style.transition = "none";
            track.style.transform = "translateX(" + (-i * step()) + "px)";
            track.getBoundingClientRect();
            track.style.transition = "";
        } else {
            track.style.transform = "translateX(" + (-i * step()) + "px)";
        }
    }

    track.addEventListener("transitionend", function () {
        if (index >= 2 * n) { index -= n; setPos(index, false); }
        if (index < n)      { index += n; setPos(index, false); }
        busy = false;
    });

    function navigate(dir) {
        if (busy) return;
        busy = true;
        index += dir;
        setPos(index, true);
    }

    if (prevBtn) prevBtn.addEventListener("click", function () { navigate(-1); });
    if (nextBtn) nextBtn.addEventListener("click", function () { navigate(1); });

    var touchStartX = 0;
    track.addEventListener("touchstart", function (e) { touchStartX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener("touchend", function (e) {
        var diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) navigate(diff > 0 ? 1 : -1);
    });

    var resizeTimer;
    window.addEventListener("resize", function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () { setPos(index, false); }, 150);
    });

    setPos(index, false);
}());
(function () {
    document.querySelectorAll('.pricing-cta').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var card = this.closest('article');
            if (!card) return;
            var name = card.querySelector('.pricing-name');
            if (!name) return;
            document.getElementById('selectedPackage').value = name.textContent.trim();
            document.getElementById('selectedPackageName').textContent = name.textContent.trim();
            document.getElementById('selectedPackageTag').removeAttribute('hidden');
        });
    });
    var clearBtn = document.getElementById('clearPackageBtn');
    if (clearBtn) clearBtn.addEventListener('click', function () {
        document.getElementById('selectedPackage').value = '';
        document.getElementById('selectedPackageTag').setAttribute('hidden', '');
    });
}());
</script>
}
