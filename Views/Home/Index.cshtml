@model SiteText
@{
    ViewData["Title"] = null;
    var heroTags = new[]
    {
        new { Name = "Webflow", Color = "#156EF6", Cls = "tag-webflow" },
        new { Name = "API",     Color = "#8468DF", Cls = "tag-api" },
        new { Name = "Figma",   Color = "#F24E1E", Cls = "tag-figma" },
        new { Name = "MySQL",   Color = "#00758F", Cls = "tag-mysql" },
        new { Name = "ASP.NET", Color = "#512BD4", Cls = "tag-aspnet" }
    };
}

<!-- ============================ HERO ============================ -->
<section class="hero">
    <div class="container hero-grid">
        <div class="hero-text">
            <span class="badge-pill">@Model.Hero.Badge</span>
            <h1 class="hero-heading">@Html.Raw(Model.Hero.HeadingHtml)</h1>
            <p class="hero-sub">@Model.Hero.Subtitle1<br />@Model.Hero.Subtitle2</p>

            <div class="hero-actions">
                <a href="#contact" class="btn btn-accent">@Model.Hero.ContactMe</a>
                <a href="#work" class="btn btn-outline-light btn-icon">
                    <img src="~/images/icons/my-work.png" alt="" /> @Model.Hero.MyWork
                </a>
            </div>

            <div class="hero-proof">
                <div class="avatars">
                    <img src="~/images/avatars/avatar1.png" alt="" />
                    <img src="~/images/avatars/avatar2.png" alt="" />
                    <img src="~/images/avatars/avatar3.png" alt="" />
                    <img src="~/images/avatars/avatar4.png" alt="" />
                    <span class="avatar-more">+5</span>
                </div>
                <span class="proof-text">@Model.Hero.ProjectsCount</span>
            </div>
        </div>

        <div class="hero-visual">
            <span class="hero-name-tag">@Model.Hero.Name</span>
            <div class="orbit">
                <span class="ring ring-1"></span>
                <span class="ring ring-2"></span>
                <span class="ring ring-3"></span>
                <img class="hero-photo" src="~/images/profile.png" alt="@Model.Hero.Name" />
                @foreach (var tag in heroTags)
                {
                    <span class="float-tag @tag.Cls" style="--tag-color:@tag.Color">@tag.Name</span>
                }
            </div>
        </div>
    </div>
</section>

<!-- ============================ WORK ============================ -->
<section class="work" id="work">
    <div class="container">
        <div class="section-head text-center">
            <span class="section-label">@Model.Work.Label</span>
            <h2 class="section-title">@Html.Raw(Model.Work.TitleHtml)</h2>
            <p class="section-sub">@Model.Work.Subtitle</p>
        </div>

        <div class="work-carousel" data-carousel>
            <button class="carousel-btn prev" data-prev aria-label="@Model.Work.PrevLabel">&#8249;</button>

            <div class="carousel-viewport">
                <div class="carousel-track" data-track>
                    @foreach (var card in Model.Work.Cards)
                    {
                        <article class="work-card">
                            <div class="work-card-img">
                                <img src="~/images/work/@card.Image" alt="@card.Title" />
                                @if (card.Duration != null)
                                {
                                    <div class="work-badge">
                                        <strong>@card.Duration</strong>
                                        <span>@card.DurationSub</span>
                                    </div>
                                }
                            </div>
                            <div class="work-card-body">
                                <h3 class="work-card-title">@card.Title</h3>
                                <p class="work-card-desc">@card.Description</p>
                                <div class="work-techs">
                                    @foreach (var tech in card.Techs)
                                    {
                                        <span class="tech-tag">@tech</span>
                                    }
                                </div>
                            </div>
                        </article>
                    }
                </div>
            </div>

            <button class="carousel-btn next" data-next aria-label="@Model.Work.NextLabel">&#8250;</button>
        </div>

        <div class="carousel-dots" data-dots></div>
    </div>
</section>

<!-- ============================ ABOUT ============================ -->
<section class="about" id="about">
    <div class="container about-grid">
        <div class="about-visual">
            <div class="orbit orbit-about">
                <span class="ring ring-1"></span>
                <span class="ring ring-2"></span>
                <img class="about-photo" src="~/images/profile.png" alt="@Model.About.Name" />
                <span class="linkedin-badge">
                    <a href="https://www.linkedin.com/in/zoran-simeunovic-3749b991" target="_blank" rel="noopener" aria-label="LinkedIn">
                        <img src="~/images/icons/linkedin-about.png" alt="LinkedIn" />
                    </a>
                </span>
                <a class="go-player" href="https://www.eurogofed.org/" target="_blank" rel="noopener" title="@Model.About.GoPlayer">
                    <img src="~/images/icons/go-game.png" alt="" />
                    <span>@Model.About.GoPlayer</span>
                </a>
            </div>
        </div>

        <div class="about-text">
            <span class="section-label">@Model.About.Label</span>
            <span class="hero-name-tag inline">@Model.About.Name</span>
            <h2 class="section-title">@Html.Raw(Model.About.HeadingHtml)</h2>
            <p class="about-desc">@Model.About.Description</p>

            <div class="about-highlights">
                <div class="hl-row">@Html.Raw(Model.About.Highlight1Html)</div>
                <div class="hl-row">@Html.Raw(Model.About.Highlight2Html)</div>
                <div class="hl-row">@Html.Raw(Model.About.Highlight3Html)</div>
            </div>

            <div class="about-actions">
                <a href="#contact" class="btn btn-accent">@Model.About.ContactMe</a>
                <a href="~/files/Lebenslauf_ZoranSimeunovic.pdf" download class="btn btn-outline-light btn-icon">
                    <img src="~/images/icons/download-cv.png" alt="" /> @Model.About.DownloadCv
                </a>
            </div>
        </div>
    </div>
</section>

<!-- ============================ PROCESS ============================ -->
<section class="process" id="process">
    <div class="container">
        <div class="section-head">
            <span class="section-label">@Model.Process.Label</span>
            <h2 class="section-title">@Html.Raw(Model.Process.TitleHtml)</h2>
        </div>

        <div class="process-grid">
            @for (var i = 0; i < Model.Process.Steps.Count; i++)
            {
                var step = Model.Process.Steps[i];
                <div class="process-card">
                    <span class="step-num">@(i + 1)</span>
                    <span class="step-tag">@step.Tag</span>
                    @if (i == 0)
                    {
                        <a href="#contact" class="btn btn-accent step-cta">@Model.Process.ContactMe</a>
                        <p class="step-desc">@Model.Process.FindMe</p>
                    }
                    else
                    {
                        <h3 class="step-title">@step.Title</h3>
                        <p class="step-desc">@step.Description</p>
                    }
                </div>
            }
        </div>
    </div>
</section>

<!-- ============================ IMPROVE ============================ -->
<section class="improve" id="improve">
    <div class="container">
        <div class="section-head">
            <h2 class="section-title">@Html.Raw(Model.Improve.TitleHtml)</h2>
            <p class="section-sub">@Model.Improve.Subtitle1<br />@Model.Improve.Subtitle2</p>
        </div>

        <div class="improve-grid">
            @foreach (var list in Model.Improve.Lists)
            {
                <div class="improve-col" data-checklist data-key="@list.Key">
                    <div class="improve-col-head">
                        <h3 class="improve-heading">@Html.Raw(list.HeadingHtml)</h3>
                        <button type="button" class="start-analysis" data-toggle-list>
                            @Model.Improve.StartAnalysis <span class="chevron">&#9662;</span>
                        </button>
                    </div>

                    <div class="improve-body" data-body hidden>
                        @foreach (var group in list.Groups)
                        {
                            <div class="check-group">
                                <h4 class="check-group-title">@group.Title</h4>
                                @foreach (var item in group.Items)
                                {
                                    <label class="check-item">
                                        <input type="checkbox" data-check />
                                        <span>@item</span>
                                    </label>
                                }
                            </div>
                        }

                        <div class="score-box" data-score>
                            @foreach (var band in list.Scores)
                            {
                                <span class="score-band" data-min="@band.Min" data-max="@band.Max" hidden>@band.Text</span>
                            }
                            <span class="score-text" data-score-text>@(list.Scores.FirstOrDefault()?.Text)</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ============================ CONTACT ============================ -->
<section class="contact" id="contact">
    <div class="container">
        <div class="contact-box">
            <h2 class="contact-title">@Html.Raw(Model.Contact.TitleHtml)</h2>
            <p class="contact-sub">@Model.Contact.Subtitle1<br />@Model.Contact.Subtitle2</p>

            <form id="contactForm" class="contact-form"
                  asp-controller="Home" asp-action="Contact" method="post">
                @Html.AntiForgeryToken()
                <input type="text" name="name" required placeholder="@Model.Contact.NamePlaceholder" />
                <input type="email" name="email" required placeholder="@Model.Contact.EmailPlaceholder" />
                <button type="submit" class="btn btn-dark-cta">@Model.Contact.GetStarted</button>
            </form>

            <p class="contact-note">@Model.Contact.PrivacyNote</p>
            <p class="contact-result" data-result hidden></p>
        </div>
    </div>
</section>
