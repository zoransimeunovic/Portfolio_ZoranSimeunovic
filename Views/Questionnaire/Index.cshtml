@using System.Text.Json
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var siteT = SiteTextProvider.Get(CultureInfo.CurrentUICulture.Name);
    var Q = siteT.Questionnaire;
    ViewData["Title"] = Q.PageTitle;
    var token = (string)ViewBag.Token;
    var name = (string)ViewBag.Name;
    var stage = (int)ViewBag.Stage;
}

<div class="q-page">
    <div class="q-container">

        <div class="q-header">
            <h1 class="q-title">@Q.PageTitle</h1>
            <p class="q-subtitle">@Q.Subtitle</p>
        </div>

        <div class="q-progress-wrap">
            <div class="q-progress-bar">
                <div class="q-progress-fill" id="progressFill"></div>
            </div>
            <span class="q-progress-label" id="progressLabel">@string.Format(Q.ProgressPattern, 1)</span>
        </div>

        <form id="qForm" data-stage="@stage" novalidate>
            <input type="hidden" id="qToken" value="@token" />

            <!-- STEP 1 -->
            <div class="q-step" id="step1">
                <h2 class="q-step-title">@Q.S1.Title</h2>

                <div class="q-field">
                    <label class="q-label" for="q1">@Q.S1.CompanyLabel <span class="q-required">*</span></label>
                    <p class="q-hint">@Q.S1.CompanyHint</p>
                    <input type="text" id="q1" name="company" class="q-input" placeholder="@Q.S1.CompanyPlaceholder" required />
                </div>

                <div class="q-field">
                    <label class="q-label" for="q2">@Q.S1.IndustryLabel</label>
                    <select id="q2" name="industry" class="q-select">
                        <option value="">@Q.SelectDefault</option>
                        @foreach (var opt in Q.S1.IndustryOptions)
                        {
                            <option>@opt</option>
                        }
                        <option value="__other__">@Q.OtherOption</option>
                    </select>
                    <input type="text" id="q2other" name="industryOther" class="q-input q-other-input" placeholder="@Q.S1.IndustryOtherPlaceholder" style="display:none" />
                </div>

                <div class="q-field">
                    <label class="q-label">@Q.S1.TeamSizeLabel</label>
                    <div class="q-radio-group">
                        @foreach (var opt in Q.S1.TeamSizeOptions)
                        {
                            <label class="q-radio-label"><input type="radio" name="teamSize" value="@opt" /> @opt</label>
                        }
                    </div>
                </div>

                <div class="q-field">
                    <label class="q-label">@Q.S1.OnlineLabel</label>
                    <div class="q-check-group">
                        @foreach (var opt in Q.S1.OnlineOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="onlinePresence" value="@opt" /> @opt</label>
                        }
                        <label class="q-check-label"><input type="checkbox" name="onlinePresence" value="Ostalo" class="q-trigger-other" data-other="onlinePresenceOther" /> @Q.OtherOption</label>
                        <input type="text" name="onlinePresenceOther" class="q-input q-other-input" placeholder="@Q.S1.OnlineOtherPlaceholder" style="display:none" />
                        <label class="q-check-label q-exclusive"><input type="checkbox" name="onlinePresence" value="Nigdje drugdje" class="q-exclusive-check" /> @Q.S1.OnlineNowhere</label>
                    </div>
                </div>

                <div class="q-field">
                    <label class="q-label">@Q.S1.HasWebsiteLabel</label>
                    <div class="q-radio-group">
                        <label class="q-radio-label"><input type="radio" name="hasWebsite" value="Da" class="q-trigger-show" data-show="websiteUrlWrap" /> @Q.S1.HasWebsiteYes</label>
                        <label class="q-radio-label"><input type="radio" name="hasWebsite" value="Ne" class="q-trigger-hide" data-hide="websiteUrlWrap" /> @Q.S1.HasWebsiteNo</label>
                    </div>
                    <div id="websiteUrlWrap" style="display:none" class="q-conditional">
                        <input type="url" name="websiteUrl" class="q-input" placeholder="@Q.S1.WebsiteUrlPlaceholder" />
                    </div>
                </div>

                <div class="q-field" id="websiteDescWrap" style="display:none">
                    <label class="q-label">@Q.S1.WebsiteDescLabel</label>
                    <div class="q-check-group">
                        @foreach (var opt in Q.S1.WebsiteDescOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="websiteDesc" value="@opt" /> @opt</label>
                        }
                        <label class="q-check-label"><input type="checkbox" name="websiteDesc" value="Ostalo" class="q-trigger-other" data-other="websiteDescOther" /> @Q.OtherOption</label>
                        <input type="text" name="websiteDescOther" class="q-input q-other-input" placeholder="@Q.S1.WebsiteDescOtherPlaceholder" style="display:none" />
                    </div>
                </div>

                <div class="q-actions q-actions--first">
                    <button type="button" class="q-btn q-btn--next" onclick="nextStep(1)">@Q.BtnNext</button>
                </div>
                <div class="q-opt-out-wrap">
                    <button type="button" class="q-opt-out-btn" onclick="optOut()">@Q.BtnOptOut</button>
                </div>
            </div>

            <!-- STEP 2 -->
            <div class="q-step" id="step2" style="display:none">
                <h2 class="q-step-title">@Q.S2.Title</h2>

                <div class="q-field">
                    <label class="q-label">@Q.S2.NeedWhatLabel</label>
                    <p class="q-hint q-hint--group">@Q.S2.HintWebsiteLabel — <em>@Q.S2.HintWebsiteEm</em></p>
                    <div class="q-radio-group">
                        @foreach (var opt in Q.S2.WebsiteTypeOptions)
                        {
                            <label class="q-radio-label"><input type="radio" name="websiteType" value="@opt" /> @opt</label>
                        }
                        <label class="q-radio-label"><input type="radio" name="websiteType" value="Nemam potrebu za web stranicom" class="q-hide-on-select" data-hide-group="pagesWrap" /> @Q.S2.WebsiteTypeNoNeed</label>
                    </div>
                    <p class="q-hint q-hint--group" style="margin-top:16px">@Q.S2.HintExtraLabel — <em>@Q.S2.HintExtraEm</em></p>
                    <div class="q-check-group">
                        <label class="q-check-label"><input type="checkbox" name="projectExtra" value="Web aplikacija" class="q-trigger-show" data-show="webAppWrap" /> @Q.S2.ProjectExtraWebApp</label>
                        @foreach (var opt in Q.S2.ProjectExtraOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="projectExtra" value="@opt" /> @opt</label>
                        }
                        <label class="q-check-label"><input type="checkbox" name="projectExtra" value="Ostalo" class="q-trigger-other" data-other="projectExtraOther" /> @Q.OtherOption</label>
                        <input type="text" name="projectExtraOther" class="q-input q-other-input" placeholder="@Q.S2.ProjectExtraOtherPlaceholder" style="display:none" />
                    </div>
                </div>

                <div class="q-field" id="pagesWrap">
                    <label class="q-label">@Q.S2.PagesLabel</label>
                    <div class="q-check-group">
                        @foreach (var opt in Q.S2.PagesOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="pages" value="@opt" /> @opt</label>
                        }
                        <label class="q-check-label"><input type="checkbox" name="pages" value="Ostalo" class="q-trigger-other" data-other="pagesOther" /> @Q.OtherOption</label>
                        <input type="text" name="pagesOther" class="q-input q-other-input" placeholder="@Q.S2.PagesOtherPlaceholder" style="display:none" />
                    </div>
                </div>

                <div class="q-field">
                    <label class="q-label">@Q.S2.FeaturesLabel</label>

                    <p class="q-group-header">@Q.S2.CommHeader</p>
                    <div class="q-check-group">
                        @foreach (var opt in Q.S2.CommOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="features" value="@opt" /> @opt</label>
                        }
                    </div>

                    <p class="q-group-header">@Q.S2.SalesHeader</p>
                    <div class="q-check-group">
                        @foreach (var opt in Q.S2.SalesOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="features" value="@opt" /> @opt</label>
                        }
                    </div>

                    <p class="q-group-header">@Q.S2.GrowthHeader</p>
                    <div class="q-check-group">
                        @foreach (var opt in Q.S2.GrowthOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="features" value="@opt" /> @opt</label>
                        }
                    </div>

                    <p class="q-group-header">@Q.S2.TechHeader</p>
                    <div class="q-check-group">
                        @foreach (var opt in Q.S2.TechOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="features" value="@opt" /> @opt</label>
                        }
                    </div>

                    <div class="q-check-group q-features-global">
                        <label class="q-check-label"><input type="checkbox" name="features" value="Ništa od navedenog" class="q-exclusive-check" /> @Q.S2.FeaturesNone</label>
                        <label class="q-check-label"><input type="checkbox" name="features" value="Ostalo" class="q-trigger-other" data-other="featuresOther" /> @Q.OtherOption</label>
                        <input type="text" name="featuresOther" class="q-input q-other-input" placeholder="@Q.S2.FeaturesOtherPlaceholder" style="display:none" />
                    </div>
                </div>

                <div class="q-field">
                    <label class="q-label">@Q.S2.ContentLabel</label>

                    <p class="q-hint q-hint--sub">@Q.S2.TextsHint</p>
                    <div class="q-radio-group">
                        @foreach (var opt in Q.ContentAvailOptions)
                        {
                            <label class="q-radio-label"><input type="radio" name="contentTexts" value="@opt" /> @opt</label>
                        }
                    </div>
                    <div class="q-dropzone q-dropzone--inline" data-label="texts" data-accept=".pdf,.doc,.docx,.txt">
                        <input type="file" class="q-dropzone-input" accept=".pdf,.doc,.docx,.txt" />
                        <div class="q-dropzone-idle">
                            <span class="q-dropzone-icon">&#8679;</span>
                            <span class="q-dropzone-hint-text">@Q.S2.TextsDropzoneHint</span>
                            <span class="q-dropzone-formats">.pdf &nbsp; .doc &nbsp; .docx &nbsp; .txt</span>
                        </div>
                        <div class="q-dropzone-progress" style="display:none">@Q.DropzoneUploading</div>
                        <div class="q-dropzone-done" style="display:none">
                            <span class="q-dz-check">&#10003;</span>
                            <span class="q-dropzone-filename"></span>
                        </div>
                        <div class="q-dropzone-err" style="display:none">@Q.DropzoneError</div>
                    </div>

                    <p class="q-hint q-hint--sub" style="margin-top:20px">@Q.S2.PhotosHint</p>
                    <div class="q-radio-group">
                        @foreach (var opt in Q.ContentAvailOptions)
                        {
                            <label class="q-radio-label"><input type="radio" name="contentPhotos" value="@opt" /> @opt</label>
                        }
                    </div>
                    <div class="q-dropzone q-dropzone--inline" data-label="photos" data-accept=".jpg,.jpeg,.png,.gif,.webp,.zip">
                        <input type="file" class="q-dropzone-input" accept=".jpg,.jpeg,.png,.gif,.webp,.zip" />
                        <div class="q-dropzone-idle">
                            <span class="q-dropzone-icon">&#8679;</span>
                            <span class="q-dropzone-hint-text">@Q.S2.PhotosDropzoneHint</span>
                            <span class="q-dropzone-formats">.jpg &nbsp; .png &nbsp; .webp &nbsp; .zip</span>
                        </div>
                        <div class="q-dropzone-progress" style="display:none">@Q.DropzoneUploading</div>
                        <div class="q-dropzone-done" style="display:none">
                            <span class="q-dz-check">&#10003;</span>
                            <span class="q-dropzone-filename"></span>
                        </div>
                        <div class="q-dropzone-err" style="display:none">@Q.DropzoneError</div>
                    </div>
                </div>

                <div class="q-field" id="webAppWrap" style="display:none">
                    <label class="q-label">@Q.S2.AppUsersLabel</label>
                    <div class="q-check-group">
                        @foreach (var opt in Q.S2.AppUsersOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="appUsers" value="@opt" /> @opt</label>
                        }
                        <label class="q-check-label"><input type="checkbox" name="appUsers" value="Ostalo" class="q-trigger-other" data-other="appUsersOther" /> @Q.OtherOption</label>
                        <input type="text" name="appUsersOther" class="q-input q-other-input" placeholder="@Q.S2.AppUsersOtherPlaceholder" style="display:none" />
                    </div>

                    <label class="q-label" style="margin-top:16px">@Q.S2.AppUserCountLabel</label>
                    <div class="q-radio-group">
                        @foreach (var opt in Q.S2.AppUserCountOptions)
                        {
                            <label class="q-radio-label"><input type="radio" name="appUserCount" value="@opt" /> @opt</label>
                        }
                    </div>
                </div>

                <div class="q-actions">
                    <button type="button" class="q-btn q-btn--back" onclick="prevStep(2)">@Q.BtnBack</button>
                    <button type="button" class="q-btn q-btn--next" onclick="nextStep(2)">@Q.BtnNext</button>
                </div>
                <div class="q-opt-out-wrap">
                    <button type="button" class="q-opt-out-btn" onclick="optOut()">@Q.BtnOptOut</button>
                </div>
            </div>

            <!-- STEP 3 -->
            <div class="q-step" id="step3" style="display:none">
                <h2 class="q-step-title">@Q.S3.Title</h2>

                <div class="q-field">
                    <label class="q-label">@Q.S3.GoalsLabel</label>

                    <p class="q-group-header">@Q.S3.WebHeader</p>
                    <div class="q-check-group">
                        @foreach (var opt in Q.S3.WebOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="goals" value="@opt" /> @opt</label>
                        }
                    </div>

                    <p class="q-group-header">@Q.S3.BusinessHeader</p>
                    <div class="q-check-group">
                        @foreach (var opt in Q.S3.BusinessOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="goals" value="@opt" /> @opt</label>
                        }
                    </div>

                    <p class="q-group-header">@Q.S3.AutoHeader</p>
                    <div class="q-check-group">
                        @foreach (var opt in Q.S3.AutoOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="goals" value="@opt" /> @opt</label>
                        }
                        <label class="q-check-label"><input type="checkbox" name="goals" value="Ostalo" class="q-trigger-other" data-other="goalsOther" /> @Q.OtherOption</label>
                        <input type="text" name="goalsOther" class="q-input q-other-input" placeholder="@Q.S3.GoalsOtherPlaceholder" style="display:none" />
                    </div>
                </div>

                <div class="q-field">
                    <label class="q-label" for="q14">@Q.S3.BiggestProblemLabel <span class="q-optional">(@Q.OptionalLabel)</span></label>
                    <p class="q-hint">@Q.S3.BiggestProblemHint</p>
                    <textarea id="q14" name="biggestProblem" class="q-textarea" rows="3"></textarea>
                </div>

                <div class="q-field">
                    <label class="q-label" for="q15">@Q.S3.SuccessCriteriaLabel <span class="q-optional">(@Q.OptionalLabel)</span></label>
                    <p class="q-hint">@Q.S3.SuccessCriteriaHint</p>
                    <textarea id="q15" name="successCriteria" class="q-textarea" rows="3"></textarea>
                </div>

                <div class="q-field">
                    <label class="q-label">@Q.S3.CustomersLabel</label>

                    <p class="q-hint q-hint--sub">@Q.S3.CustomerTypeHint</p>
                    <div class="q-check-group">
                        <label class="q-check-label"><input type="checkbox" name="customerType" value="Privatne osobe" class="q-trigger-show" data-show="customerDemoWrap" /> @Q.S3.CustomerTypePrivate</label>
                        <label class="q-check-label"><input type="checkbox" name="customerType" value="Druga preduzeća i firme" /> @Q.S3.CustomerTypeBusiness</label>
                        <label class="q-check-label"><input type="checkbox" name="customerType" value="I privatne osobe i firme" class="q-trigger-show" data-show="customerDemoWrap" /> @Q.S3.CustomerTypeBoth</label>
                        <label class="q-check-label"><input type="checkbox" name="customerType" value="Ostalo" class="q-trigger-other" data-other="customerTypeOther" /> @Q.OtherOption</label>
                        <input type="text" name="customerTypeOther" class="q-input q-other-input" placeholder="@Q.S3.CustomerTypeOtherPlaceholder" style="display:none" />
                    </div>

                    <div id="customerDemoWrap" style="display:none" class="q-conditional">
                        <p class="q-hint q-hint--sub">@Q.S3.AgeHint</p>
                        <div class="q-check-group">
                            @foreach (var opt in Q.S3.AgeOptions)
                            {
                                <label class="q-check-label"><input type="checkbox" name="ageGroup" value="@opt" /> @opt</label>
                            }
                        </div>

                        <p class="q-hint q-hint--sub">@Q.S3.GenderHint</p>
                        <div class="q-check-group">
                            @foreach (var opt in Q.S3.GenderOptions)
                            {
                                <label class="q-check-label"><input type="checkbox" name="gender" value="@opt" /> @opt</label>
                            }
                        </div>
                    </div>

                    <p class="q-hint q-hint--sub">@Q.S3.LocationHint</p>
                    <div class="q-radio-group">
                        @foreach (var opt in Q.S3.LocationOptions)
                        {
                            <label class="q-radio-label"><input type="radio" name="customerLocation" value="@opt" /> @opt</label>
                        }
                    </div>
                </div>

                <div class="q-field">
                    <label class="q-label">@Q.S3.BrandingLabel</label>
                    <p class="q-hint">@Q.S3.BrandingHint</p>
                    <div class="q-dropzones-row">
                        <div class="q-dropzone" data-label="logo" data-accept=".jpg,.jpeg,.png,.gif,.svg,.pdf,.ai,.eps">
                            <input type="file" class="q-dropzone-input" accept=".jpg,.jpeg,.png,.gif,.svg,.pdf,.ai,.eps" />
                            <div class="q-dropzone-idle">
                                <span class="q-dropzone-icon">&#8679;</span>
                                <p class="q-dropzone-title">@Q.S3.LogoTitle</p>
                                <p class="q-dropzone-hint-text">@Q.DropzoneClickOrDrag</p>
                                <p class="q-dropzone-formats">.jpg .png .svg .pdf .ai</p>
                            </div>
                            <div class="q-dropzone-progress" style="display:none">@Q.DropzoneUploading</div>
                            <div class="q-dropzone-done" style="display:none">
                                <span class="q-dz-check">&#10003;</span>
                                <span class="q-dropzone-filename"></span>
                            </div>
                            <div class="q-dropzone-err" style="display:none">@Q.DropzoneError</div>
                        </div>
                        <div class="q-dropzone" data-label="brandbook" data-accept=".pdf,.doc,.docx">
                            <input type="file" class="q-dropzone-input" accept=".pdf,.doc,.docx" />
                            <div class="q-dropzone-idle">
                                <span class="q-dropzone-icon">&#8679;</span>
                                <p class="q-dropzone-title">@Q.S3.BrandBookTitle</p>
                                <p class="q-dropzone-hint-text">@Q.DropzoneClickOrDrag</p>
                                <p class="q-dropzone-formats">.pdf .doc .docx</p>
                            </div>
                            <div class="q-dropzone-progress" style="display:none">@Q.DropzoneUploading</div>
                            <div class="q-dropzone-done" style="display:none">
                                <span class="q-dz-check">&#10003;</span>
                                <span class="q-dropzone-filename"></span>
                            </div>
                            <div class="q-dropzone-err" style="display:none">@Q.DropzoneError</div>
                        </div>
                    </div>
                    <div class="q-check-group" style="margin-top:16px">
                        @foreach (var opt in Q.S3.BrandingOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="branding" value="@opt" /> @opt</label>
                        }
                        <label class="q-check-label"><input type="checkbox" name="branding" value="Ostalo" class="q-trigger-other" data-other="brandingOther" /> @Q.OtherOption</label>
                        <input type="text" name="brandingOther" class="q-input q-other-input" placeholder="@Q.S3.BrandingOtherPlaceholder" style="display:none" />
                    </div>
                </div>

                <div class="q-field">
                    <label class="q-label">@Q.S3.StyleLabel</label>
                    <div class="q-check-group">
                        @foreach (var opt in Q.S3.StyleOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="style" value="@opt" /> @opt</label>
                        }
                        <label class="q-check-label"><input type="checkbox" name="style" value="Ostalo" class="q-trigger-other" data-other="styleOther" /> @Q.OtherOption</label>
                        <input type="text" name="styleOther" class="q-input q-other-input" placeholder="@Q.S3.StyleOtherPlaceholder" style="display:none" />
                    </div>
                </div>

                <div class="q-field">
                    <label class="q-label" for="q19">@Q.S3.ReferenceLinksLabel <span class="q-optional">(@Q.OptionalLabel)</span></label>
                    <p class="q-hint">@Q.S3.ReferenceLinksHint</p>
                    <textarea id="q19" name="referenceLinks" class="q-textarea" rows="2"></textarea>
                </div>

                <div class="q-field">
                    <label class="q-label" for="q20">@Q.S3.ExistingSystemsLabel <span class="q-optional">(@Q.OptionalLabel)</span></label>
                    <p class="q-hint">@Q.S3.ExistingSystemsHint</p>
                    <textarea id="q20" name="existingSystems" class="q-textarea" rows="2"></textarea>
                </div>

                <div class="q-field">
                    <label class="q-label" for="q21">@Q.S3.CompetitorLinksLabel <span class="q-optional">(@Q.OptionalLabel)</span></label>
                    <p class="q-hint">@Q.S3.CompetitorLinksHint</p>
                    <textarea id="q21" name="competitorLinks" class="q-textarea" rows="2"></textarea>
                </div>

                <div class="q-field">
                    <label class="q-label">@Q.S3.StartWhenLabel</label>
                    <div class="q-radio-group">
                        @foreach (var opt in Q.S3.StartWhenOptions)
                        {
                            <label class="q-radio-label"><input type="radio" name="startWhen" value="@opt" /> @opt</label>
                        }
                        <label class="q-radio-label"><input type="radio" name="startWhen" value="Ostalo" class="q-trigger-other" data-other="startWhenOther" /> @Q.OtherOption</label>
                        <input type="text" name="startWhenOther" class="q-input q-other-input" placeholder="@Q.S3.StartWhenOtherPlaceholder" style="display:none" />
                    </div>
                </div>

                <div class="q-field">
                    <label class="q-label">@Q.S3.DeadlineLabel</label>
                    <div class="q-radio-group">
                        <label class="q-radio-label"><input type="radio" name="deadline" value="Da" class="q-trigger-show" data-show="deadlineDateWrap" /> @Q.S3.DeadlineYes</label>
                        <label class="q-radio-label"><input type="radio" name="deadline" value="Ne" class="q-trigger-hide" data-hide="deadlineDateWrap" /> @Q.S3.DeadlineNo</label>
                        <label class="q-radio-label"><input type="radio" name="deadline" value="Fleksibilno" class="q-trigger-hide" data-hide="deadlineDateWrap" /> @Q.S3.DeadlineFlexible</label>
                    </div>
                    <div id="deadlineDateWrap" style="display:none" class="q-conditional">
                        <input type="date" name="deadlineDate" class="q-input" />
                    </div>
                </div>

                <div class="q-field">
                    <label class="q-label">@Q.S3.RankingLabel <span class="q-hint-inline">@Q.S3.RankingHintInline</span></label>
                    <div class="q-ranking">
                        <div class="q-ranking-row">
                            <span class="q-ranking-label">@Q.S3.RankSpeedLabel</span>
                            <select name="rankSpeed" class="q-rank-select" data-rank-group="main">
                                <option value="">—</option>
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="3">3</option>
                            </select>
                        </div>
                        <div class="q-ranking-row">
                            <span class="q-ranking-label">@Q.S3.RankQualityLabel</span>
                            <select name="rankQuality" class="q-rank-select" data-rank-group="main">
                                <option value="">—</option>
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="3">3</option>
                            </select>
                        </div>
                        <div class="q-ranking-row">
                            <span class="q-ranking-label">@Q.S3.RankPriceLabel</span>
                            <select name="rankPrice" class="q-rank-select" data-rank-group="main">
                                <option value="">—</option>
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="3">3</option>
                            </select>
                        </div>
                        <p class="q-rank-error" id="rankError" style="display:none">@Q.S3.RankError</p>
                    </div>
                </div>

                <div class="q-field">
                    <label class="q-label">@Q.S3.SupportLabel</label>
                    <div class="q-radio-group">
                        @foreach (var opt in Q.S3.SupportOptions)
                        {
                            <label class="q-radio-label"><input type="radio" name="support" value="@opt" /> @opt</label>
                        }
                    </div>
                </div>

                <div class="q-field">
                    <label class="q-label">@Q.S3.HeardFromLabel</label>
                    <div class="q-check-group">
                        @foreach (var opt in Q.S3.HeardFromOptions)
                        {
                            <label class="q-check-label"><input type="checkbox" name="heardFrom" value="@opt" /> @opt</label>
                        }
                        <label class="q-check-label"><input type="checkbox" name="heardFrom" value="Ostalo" class="q-trigger-other" data-other="heardFromOther" /> @Q.OtherOption</label>
                        <input type="text" name="heardFromOther" class="q-input q-other-input" placeholder="@Q.S3.HeardFromOtherPlaceholder" style="display:none" />
                    </div>
                </div>

                <div class="q-field">
                    <label class="q-label" for="q27">@Q.S3.AdditionalNotesLabel <span class="q-optional">(@Q.OptionalLabel)</span></label>
                    <p class="q-hint">@Q.S3.AdditionalNotesHint</p>
                    <textarea id="q27" name="additionalNotes" class="q-textarea" rows="3"></textarea>
                </div>

                <div class="q-actions">
                    <button type="button" class="q-btn q-btn--back" onclick="prevStep(3)">@Q.BtnBack</button>
                    <button type="button" class="q-btn q-btn--submit" id="submitBtn" onclick="submitForm()">@Q.BtnSubmit</button>
                </div>
                <div class="q-opt-out-wrap">
                    <button type="button" class="q-opt-out-btn" onclick="optOut()">@Q.BtnOptOut</button>
                </div>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <script>
        window.QText = @Html.Raw(JsonSerializer.Serialize(new
        {
            progressPattern = Q.ProgressPattern,
            progressDone = Q.ProgressDone,
            btnSending = Q.BtnSending,
            companyRequired = Q.CompanyRequired,
            optOutConfirm = Q.OptOutConfirmMsg,
            optOutDoneHtml = Q.OptOutDoneHtml,
            optOutError = Q.OptOutError
        }));
    </script>
    <script src="~/js/questionnaire.js" asp-append-version="true"></script>
}
